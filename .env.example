# --- Telegram ---
TG_BOT_TOKEN=           # from @BotFather
TG_WEBHOOK_SECRET=      # random 32+ char string, you choose
TG_ALLOWED_CHAT_ID=     # id of RIP CS2 group (bot will refuse to work elsewhere). Set after first /whereami in group
TG_ADMIN_IDS=           # comma-separated tg user ids who can /warn /ban /mute

# --- Cerebras ---
CEREBRAS_API_KEY=       # from cloud.cerebras.ai
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# --- Supabase Postgres ---
# Use the "Session pooler" or direct connection URI from Supabase dashboard
# Format: postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Steam ---
STEAM_API_KEY=          # from steamcommunity.com/dev/apikey

# --- Mistral (embeddings for semantic memory) ---
MISTRAL_API_KEY=        # from admin.mistral.ai/organization/api-keys

# --- Server ---
PUBLIC_BASE_URL=        # your Render URL, e.g. https://kairo.onrender.com
PORT=10000              # Render injects this; local default 10000
LOG_LEVEL=INFO

# --- Embeddings ---
EMBED_MODEL=mistral-embed
EMBED_DIM=1024

# --- Behaviour knobs ---
CHAT_HISTORY_LIMIT=30           # how many recent msgs to feed into AI prompt
MEMORY_TOP_K=5                  # top-K semantic memories injected
MEMORY_EXTRACT_EVERY=20         # run extractor every N new group messages
RATE_LIMIT_PER_MINUTE=20        # max msgs per user per minute before antispam kicks in
